---
extends: default

rules:
  line-length:
    max: 200
    level: warning
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
  comments:
    min-spaces-from-content: 1
  indentation:
    indent-sequences: consistent
  document-start: disable

ignore: |
  .github/
  roles/containers/files/
