---
profile: basic

exclude_paths:
  - .github/
  - roles/containers/files/
  - scripts/
  # Standalone playbook using the external artis3n.tailscale role, which isn't
  # installed in the lint environment (CI installs collections only, not roles).
  - tailscale.yml

skip_list:
  - yaml[line-length]
  - name[casing]
  # Pre-existing repo conventions, deliberately not enforced (2026-06 lint pass):
  - var-naming[no-role-prefix]   # `<svc>_service` facts & role vars intentionally unprefixed
  - name[missing]                # include_tasks and some tasks left unnamed
  - name[template]
  - key-order[task]
  - command-instead-of-module    # intentional curl/shell usage in bootstrap tasks
  - command-instead-of-shell
  - partial-become[task]
